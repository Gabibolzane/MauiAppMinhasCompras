<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
            x:Class="MauiAppMinhasCompras.Views.NovoProduto"
            Title="Novo Produto">

    <!-- Barra superior da página -->
    <ContentPage.ToolbarItems>
        <!-- Botão "Salvar" que chama o método ToolbarItem_Clicked quando clicado -->
        <ToolbarItem Text="Salvar" Clicked="ToolbarItem_Clicked"/>
    </ContentPage.ToolbarItems>

    <!-- Layout vertical que organiza os elementos-->
    <VerticalStackLayout Spacing="10" Padding="10">
        <!-- Texto indicando o campo de descrição -->
        <Label Text="Descrição do Produto:"/>
        <!-- Campo onde o usuário digita a descrição do produto -->
        <Entry x:Name="txt_descricao"/>
        <!-- Texto indicando o campo de quantidade -->
        <Label Text="Quantidade: "/>
        <!-- Campo para digitar a quantidade -->
        <Entry x:Name="txt_quantidade" Keyboard="Numeric"/>
        <!-- Texto indicando o campo de preço -->
        <Label Text="Preço unitário: "/>
        <!-- Campo para digitar o preço do produto -->
        <Entry x:Name="txt_preco" Keyboard="Numeric"/>

    </VerticalStackLayout>
</ContentPage>